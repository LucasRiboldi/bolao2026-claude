rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'lucasriboldi.dev@gmail.com';
    }


    match /users/{uid} {
      // Admin pode listar todos os usuários
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      // Necessário para o saveProfile criar o doc pai
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());

      match /profile/{doc} {
        allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      match /bets/{doc} {
        allow read: if request.auth != null;
        // Users limited to 100 keys (allows 72 group games + small buffer).
        // Admin has no size limit — needed for seed/bulk operations.
        allow create, update:
          if request.auth != null
             && (
                  (request.auth.uid == uid && request.resource.data.size() <= 100)
                  || isAdmin()
                );
        allow delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }
    }

    // collectionGroup 'profile' — permite admin listar todos os perfis
    // (necessário para loadAdminUserList e loadAllUsersForRanking via collectionGroup)
    match /{path=**}/profile/{doc} {
      allow read: if isAdmin();
    }

    // collectionGroup 'bets' — admin precisa para ranking completo
    match /{path=**}/bets/{doc} {
      allow read: if request.auth != null;
    }

    match /results/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /ranking/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /config/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // Email banlist — public read so AuthScreen can check during signup
    // (no auth context available pre-signup); admin-only write.
    match /blocked/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

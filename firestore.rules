rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'lucasriboldi.dev@gmail.com';
    }

    // Valida que os dados de apostas de grupos têm tamanho razoável
    // e que valores de gols (se presentes) são strings numéricas entre 0 e 20
    function validGroupBetDoc(data) {
      return data.size() <= 80
          && (!data.keys().hasAny(['homeGoals'])
              || (data.homeGoals is string && data.homeGoals.matches('^(0|[1-9]|1[0-9]|20)$')));
    }

    match /users/{uid} {
      // Admin pode listar todos os usuários
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      // Necessário para o saveProfile criar o doc pai
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());

      match /profile/{doc} {
        allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
      }

      match /bets/{doc} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && (request.auth.uid == uid || isAdmin())
                        && request.resource.data.size() <= 100;
      }
    }

    // collectionGroup 'profile' — permite admin listar todos os perfis
    // (necessário para loadAdminUserList e loadAllUsersForRanking via collectionGroup)
    match /{path=**}/profile/{doc} {
      allow read: if isAdmin();
    }

    // collectionGroup 'bets' — admin precisa para ranking completo
    match /{path=**}/bets/{doc} {
      allow read: if request.auth != null;
    }

    match /results/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /ranking/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /config/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

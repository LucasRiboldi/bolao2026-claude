{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      "CLAUDE.md",
      "README.md",
      "node_modules/**",
      ".git/**",
      "package*.json",
      "seed*.js",
      "seed*.html",
      "service-account.json",
      "*.serviceAccount.json"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [{ "key": "Cache-Control", "value": "public,max-age=3600" }]
      }
    ]
  }
}
